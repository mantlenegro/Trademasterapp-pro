{
  "expo": {
    "name": "Trading Academy Pro",
    "slug": "trading-academy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark", 
    "backgroundColor": "#0F172A",
    
    "ios": {
      "bundleIdentifier": "com.tradingacademy.app",
      "supportsTablet": true
    },

    "android": {
      "package": "com.tradingacademy.app",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      }
    },

    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9598335800956469~1158817426",
          "iosAppId": "ca-app-pub-9598335800956469~1158817426",
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you."
        }
      ],
      "expo-notifications",
      "expo-print",
      "expo-sharing"
    ],

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },

    "extra": {
      "eas": {
        "projectId": "YOUR_PROJECT_ID_HERE"
      }
    }
  }
}
